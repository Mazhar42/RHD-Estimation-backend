# Production Environment Variables Template
# Copy this file to .env.prod and fill in the actual values (NEVER commit sensitive data)

# App Configuration
APP_ENV=production

# CRITICAL: Generate a strong SECRET_KEY using: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# DO NOT use a weak default value
SECRET_KEY=your-strong-secret-key-here

# Database Configuration - Use strong passwords in production
DB_USER=rhd_estimation_user
DB_PASSWORD=your-strong-password-here
DB_HOST=db
DB_PORT=5432
DB_NAME=rhd_estimation
DATABASE_URL=postgresql://rhd_estimation_user:your-strong-password-here@db:5432/rhd_estimation

# CORS Configuration - Update with your actual frontend domain
CORS_ORIGINS=https://your-frontend-domain.com

# Frontend URL (for redirects)
FRONTEND_URL=https://your-frontend-domain.com

# Logging Level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Optional: pgAdmin credentials (if using pgAdmin in production monitoring)
# PGADMIN_EMAIL=admin@example.com
# PGADMIN_PASSWORD=strong-password-here
